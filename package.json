{
  "name": "litestay",
  "version": "1.0.0",
  "type": "module",
  "description": "民宿前台管理系统 - 纯本地单机版 PMS",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dev:web": "vite",
    "build": "vite build",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:all": "vite build && electron-builder --win --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "exceljs": "^4.4.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^17.0.8",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.litestay.pms",
    "productName": "LiteStay",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "node_modules/**/*",
      "!node_modules/**/test/**",
      "!node_modules/**/*.md",
      "!src/**"
    ],
    "extraResources": [],
    "asar": true,
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-win.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "LiteStay",
      "installerLanguages": ["zh_CN", "en_US"]
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "arch": [
        "x64",
        "arm64"
      ],
      "artifactName": "${productName}-${version}-mac.${ext}"
    }
  }
}
